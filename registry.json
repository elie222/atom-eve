{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "atom-eve",
  "homepage": "https://atomeve.dev",
  "items": [
    {
      "name": "stripe-pulse",
      "type": "registry:block",
      "title": "Stripe Revenue & Churn Pulse",
      "description": "Writes a grounded weekly revenue and churn pulse from Stripe facts, cross-references at-risk customers against PostHog engagement, and posts it to Slack.",
      "dependencies": [
        "@vercel/connect@^0.2.10",
        "ai@^7.0.4",
        "eve@^0.16.2"
      ],
      "files": [
        {
          "path": "registry/stripe-pulse/agent/agent.ts",
          "target": "~/agent/agent.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/channels/eve.ts",
          "target": "~/agent/channels/eve.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/channels/slack.ts",
          "target": "~/agent/channels/slack.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/instructions.md",
          "target": "~/agent/instructions.md",
          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/sandbox/sandbox.ts",
          "target": "~/agent/sandbox/sandbox.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/sandbox/workspace/scripts/engagement.sh",
          "target": "~/agent/sandbox/workspace/scripts/engagement.sh",
