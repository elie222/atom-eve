{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "atom-eve",
  "homepage": "https://atomeve.dev",
  "items": [
    {
      "name": "eve/website-qa",
      "type": "registry:block",
      "title": "Website QA Agent (eve)",
      "description": "Runs browser-driven QA on signup, onboarding, and other web app flows.",
      "files": [
        {
          "path": "registry/website-qa/shared/instructions.md",
          "target": "~/agent/instructions.md",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/targets/eve/agent.ts",
          "target": "~/agent/agent.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/targets/eve/sandbox/sandbox.ts",
          "target": "~/agent/sandbox/sandbox.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/targets/eve/sandbox/workspace/setup-agent-browser.sh",
          "target": "~/agent/sandbox/workspace/setup-agent-browser.sh",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/evals/eve/evals.config.ts",
          "target": "~/evals/evals.config.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/evals/eve/shared/website-qa-smoke.ts",
          "target": "~/evals/shared/website-qa-smoke.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/website-qa/evals/eve/website-qa/example-homepage.eval.ts",
          "target": "~/evals/website-qa/example-homepage.eval.ts",
          "type": "registry:file"
        }
      ]
    },
    {
      "name": "flue/website-qa",
      "type": "registry:block",
      "title": "Website QA Agent (flue)",
      "description": "Runs browser-driven QA on signup, onboarding, and other web app flows.",
      "files": [
        {
          "path": "registry/website-qa/targets/flue/agent.ts",
          "target": "~/src/agents/website-qa.ts",
          "type": "registry:file"
        }
      ]
    },
    {
      "name": "eve/facebook-ads",
      "type": "registry:block",
      "title": "Facebook Ads Agent (eve)",
      "description": "Reviews campaign performance and proposes daily budget and creative actions.",
      "files": [
        {
          "path": "registry/facebook-ads/shared/instructions.md",
          "target": "~/agent/instructions.md",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/shared/skills/daily-loop.md",
          "target": "~/agent/skills/daily-loop.md",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/shared/lib/facebook.ts",
          "target": "~/agent/lib/facebook.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/targets/eve/agent.ts",
          "target": "~/agent/agent.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/targets/eve/tools/review_campaigns.ts",
          "target": "~/agent/tools/review_campaigns.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/targets/eve/schedules/daily.ts",
          "target": "~/agent/schedules/daily.ts",
          "type": "registry:file"
        }
      ]
    },
    {
      "name": "flue/facebook-ads",
      "type": "registry:block",
      "title": "Facebook Ads Agent (flue)",
      "description": "Reviews campaign performance and proposes daily budget and creative actions.",
      "files": [
        {
          "path": "registry/facebook-ads/targets/flue/agent.ts",
          "target": "~/src/agents/facebook-ads.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/shared/skills/daily-loop.md",
          "target": "~/src/skills/facebook-ads-daily-loop/SKILL.md",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/shared/lib/facebook.ts",
          "target": "~/src/lib/agents/facebook-ads/facebook.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/targets/flue/tools/facebook.ts",
          "target": "~/src/tools/facebook-ads/facebook.ts",
          "type": "registry:file"
        },
        {
          "path": "registry/facebook-ads/targets/flue/workflows/daily.ts",
          "target": "~/src/workflows/facebook-ads-daily.ts",
          "type": "registry:file"
        }
      ]
    }
  ]
}
