          "type": "registry:file"
        },
        {
          "path": "registry/stripe-pulse/agent/skills/revenue-pulse/SKILL.md",
          "target": "~/agent/skills/revenue-pulse/SKILL.md",
          "type": "registry:file"
        }
      ]
    }
  ]
