{
  "name": "atom-eve",
  "version": "0.1.0",
  "private": false,
  "description": "Install Atom Eve agents into Eve projects.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "atom-eve": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://atomeve.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elie222/atom-eve.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "eve",
    "agents",
    "ai",
    "shadcn",
    "registry",
    "atom-eve"
  ],
  "scripts": {
    "build": "pnpm --filter @atom-eve/install-map build && pnpm --filter @atom-eve/flue-generator build && tsup && chmod +x dist/index.js",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@atom-eve/flue-generator": "workspace:*",
    "@atom-eve/install-map": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "^5.7.2"
  }
}
