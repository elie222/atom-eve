---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Glyph from "../../components/Glyph.astro";
import InstallBox from "../../components/InstallBox.tsx";
import ContentTabs from "../../components/ContentTabs.tsx";
import {
  getItems,
  getReadmeHtml,
  getManifest,
  variantsOf,
  type RegistryItem,
} from "../../lib/data";
import { catGlyph, famColor, highlightJson, prettify, REPO, targetLabel } from "../../lib/format";

export function getStaticPaths() {
  const items = getItems();
  return items.map((item) => ({
    params: { name: item.name },
    props: {
      item,
      readmeHtml: getReadmeHtml(item),
      manifestHtml: highlightJson(getManifest(item)),
      variants: variantsOf(item, items).map((v) => ({
        name: v.name,
        description: v.description,
        version: v.version,
      })),
    },
  }));
}

interface Props {
  item: RegistryItem;
  readmeHtml: string;
  manifestHtml: string;
  variants: { name: string; description: string; version: string }[];
}

const { item, readmeHtml, manifestHtml, variants } = Astro.props as Props;

const color = famColor(item.family);
const glyph = catGlyph(item.category);
const frameworks = (item.targets ?? []).map(targetLabel);
const integrations = item.integrations ?? [];
const requiredEnv = item.requiredEnv ?? [];

const about: { k: string; v: string; accent?: boolean }[] = [
  { k: "Version", v: item.version },
  { k: "License", v: "MIT" },
  { k: "Memory", v: item.memory ? "Yes" : "No", accent: item.memory },
  { k: "Frameworks", v: frameworks.join(" · ") },
  { k: "Scheduled", v: item.scheduled ? "Yes" : "No" },
];
---

<Base title={`${item.title} — Atom Eve`} description={item.description}>
  <Nav />

  <div class="mx-auto max-w-[1120px] px-8 pb-20 pt-[34px]">
    <!-- breadcrumb -->
    <div class="font-mono text-[12px] text-dim">
      <a href="/" class="text-muted transition-colors hover:text-ink">Browse</a>
      <span class="text-dim2">/</span>
      <span class="text-eve">{prettify(item.family)}</span>
      <span class="text-dim2">/</span>
      <span class="text-ink2">{item.title}</span>
    </div>

    <!-- header -->
    <div class="mt-[22px] flex flex-wrap items-start gap-[18px]">
      <div
        class="flex h-[54px] w-[54px] flex-none items-center justify-center rounded-xl"
        style={`background:${color}1f;border:1px solid ${color}4d`}
      >
        <Glyph glyph={glyph} color={color} scale={5} />
      </div>
      <div class="min-w-[280px] flex-1">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="m-0 text-[34px] font-bold tracking-[-0.02em]">{item.title}</h1>
          <span
            class="rounded-[5px] px-[9px] py-[3px] font-mono text-[12px] text-eve"
            style="background:rgba(155,255,92,0.10);border:1px solid rgba(155,255,92,0.34)"
            >v{item.version}</span
          >
          {
            item.memory ? (
              <span
                class="whitespace-nowrap rounded-[5px] px-[9px] py-[3px] font-mono text-[11px] text-eve"
                style="background:rgba(155,255,92,0.10);border:1px solid rgba(155,255,92,0.30)"
              >
                ● MEMORY
              </span>
            ) : (
              <span class="whitespace-nowrap rounded-[5px] border border-edge px-[9px] py-[3px] font-mono text-[11px] text-muted">
                STATELESS
              </span>
            )
          }
        </div>
        <div class="mt-2 text-[17px] text-ink2">{item.description}</div>
        <div class="mt-3 flex flex-wrap gap-[14px] font-mono text-[12.5px] text-muted">
          <span>{prettify(item.family)} / {prettify(item.category)}</span>
          <span class="text-dim2">·</span>
          <span>{frameworks.join(" · ")}</span>
          <span class="text-dim2">·</span>
          <span>MIT</span>
        </div>
      </div>
    </div>

    <!-- install (React island) -->
    <InstallBox client:load name={item.name} targets={item.targets ?? []} />

    <!-- content + sidebar -->
    <div class="detail-grid mt-[34px] grid grid-cols-[1fr_318px] items-start gap-9 max-md:grid-cols-1">
      <ContentTabs client:load readmeHtml={readmeHtml} manifestHtml={manifestHtml} />

      <aside class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
          <a
            href="#install"
            class="rounded-[7px] bg-eve px-4 py-[11px] text-center text-[13.5px] font-semibold text-[#0a0a0c] transition-[filter] hover:brightness-[1.08]"
            >Deploy this agent</a
          >
          <a
            href={REPO}
            class="rounded-[7px] border border-edge px-4 py-[11px] text-center text-[13.5px] font-medium text-ink transition-colors hover:bg-panel2"
            >View on GitHub ↗</a
          >
        </div>

        <div class="rounded-[9px] border border-edge bg-panel px-4 py-[15px]">
          <div class="mb-3 font-mono text-[10.5px] tracking-[0.06em] text-dim">ABOUT</div>
          <div class="flex flex-col gap-[10px] text-[13.5px]">
            {
              about.map((row) => (
                <div class="flex justify-between gap-3">
                  <span class="text-muted2">{row.k}</span>
                  <span
                    class="text-right font-mono text-[12.5px]"
                    style={row.accent ? "color:#9bff5c" : "color:#eef0ff"}
                  >
                    {row.v}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        {
          integrations.length > 0 && (
            <div class="rounded-[9px] border border-edge bg-panel px-4 py-[15px]">
              <div class="mb-3 font-mono text-[10.5px] tracking-[0.06em] text-dim">INTEGRATIONS</div>
              <div class="flex flex-wrap gap-[7px]">
                {integrations.map((s) => (
                  <span class="rounded-[5px] border border-edge bg-bg2 px-[9px] py-[5px] font-mono text-[11.5px] text-ink2">
                    {prettify(s)}
                  </span>
                ))}
              </div>
            </div>
          )
        }

        {
          variants.length > 0 ? (
            <div class="rounded-[9px] border border-edge bg-panel px-4 py-[15px]">
              <div class="font-mono text-[10.5px] tracking-[0.06em] text-dim">
                OTHER VARIANTS · {prettify(item.category).toUpperCase()}
              </div>
              <div class="mb-3 mt-1 text-[12px] text-muted2">Same task, different builds.</div>
              {variants.map((v) => (
                <a
                  href={`/agents/${v.name}/`}
                  class="flex items-center justify-between border-t border-edgedim py-[9px]"
                >
                  <span>
                    <span class="text-[13.5px] text-ink2">{v.description.slice(0, 40)}</span>
                    <br />
                    <span class="font-mono text-[11px] text-muted2">v{v.version}</span>
                  </span>
                  <span class="whitespace-nowrap font-mono text-[11px] text-dim">→</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="rounded-[9px] border border-edge bg-panel px-4 py-[15px]">
              <div class="mb-[10px] font-mono text-[10.5px] tracking-[0.06em] text-dim">
                REQUIRED ENV
              </div>
              {requiredEnv.length > 0 ? (
                requiredEnv.map((e) => (
                  <div class="flex items-center justify-between border-t border-edgedim py-[9px]">
                    <span class="font-mono text-[12px] text-eve">{e}</span>
                    <span class="font-mono text-[11px] text-dim">required</span>
                  </div>
                ))
              ) : (
                <div class="text-[13px] text-muted">No keys required.</div>
              )}
            </div>
          )
        }
      </aside>
    </div>
  </div>

  <Footer />
</Base>
