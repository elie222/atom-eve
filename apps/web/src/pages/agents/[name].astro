---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Glyph from "../../components/Glyph.astro";
import InstallBox from "../../components/InstallBox.tsx";
import { getItems, getReadmeHtml, variantsOf, type RegistryItem } from "../../lib/data";
import { catGlyph, famColor, prettify, REPO } from "../../lib/format";

export function getStaticPaths() {
  const items = getItems();
  return items.map((item) => ({
    params: { name: item.name },
    props: {
      item,
      readmeHtml: getReadmeHtml(item),
      variants: variantsOf(item, items).map((v) => ({
        name: v.name,
        title: v.title,
      })),
    },
  }));
}

interface Props {
  item: RegistryItem;
  readmeHtml: string;
  variants: { name: string; title: string }[];
}

const { item, readmeHtml, variants } = Astro.props as Props;

const color = famColor(item.family);
const glyph = catGlyph(item.category);
const frameworks = item.targets ?? [];
const integrations = item.integrations ?? [];
const requiredEnv = item.requiredEnv ?? [];

// "Paste into your agent" prompt for this specific agent.
const promptName = item.title.toLowerCase().endsWith("agent") ? item.title : `${item.title} agent`;
const pastePrompt = `Read atomeve.dev/start.md and add ${promptName} to my project.`;

const about: { k: string; v: string; accent?: boolean }[] = [
  { k: "Category", v: `${prettify(item.family)} / ${prettify(item.category)}` },
  { k: "Frameworks", v: frameworks.join(" · ") },
  { k: "Version", v: `v${item.version}` },
  { k: "State", v: item.memory ? "Memory" : "Stateless", accent: item.memory },
  { k: "Scheduled", v: item.scheduled ? "Yes" : "No" },
];
const sourceUrl = `${REPO}/tree/main/${item.repoPath}`;
---

<Base title={`${item.title} — Atom Eve`} description={item.description}>
  <Nav variant="detail" />

  <div class="relative z-[2] mx-auto max-w-[1200px] px-[30px] pb-20 pt-[30px] max-sm:px-4">
    <!-- header -->
    <div class="flex flex-wrap items-start gap-[18px]">
      <div
        class="flex h-[56px] w-[56px] flex-none items-center justify-center"
        style={`background:${color}1f;border:2px solid ${color}4d`}
      >
        <Glyph glyph={glyph} color={color} scale={5} />
      </div>
      <div class="min-w-[280px] flex-1">
        <h1 class="m-0 text-[34px] font-bold leading-[1.08]">{item.title}</h1>
        <div class="mt-[10px] text-[16.5px] text-ink2">{item.description}</div>
      </div>
    </div>

    <!-- install (React island) -->
    <InstallBox client:load name={item.name} targets={item.targets ?? []} />

    <!-- or paste into your agent -->
    <div
      class="mt-3 border-2 border-edge bg-code"
      style="box-shadow:4px 4px 0 rgba(0,0,0,0.35)"
    >
      <div class="flex items-center gap-2 border-b-2 border-edgedim px-4 py-[10px]">
        <span class="h-[9px] w-[9px] bg-pink"></span>
        <span class="h-[9px] w-[9px] bg-amber"></span>
        <span class="h-[9px] w-[9px] bg-cyan"></span>
        <span class="ml-[6px] font-pixel text-[8px] tracking-[0.06em] text-dim"
          >OR PASTE INTO YOUR AGENT</span
        >
      </div>
      <div class="flex items-center gap-[14px] px-[18px] py-[14px]">
        <code
          class="min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap font-mono text-[13px] text-ink2"
          ><span class="text-cyan">▸</span> {pastePrompt}</code
        >
        <button
          type="button"
          class="copy-btn arcade-btn flex-none whitespace-nowrap bg-cyan px-[13px] py-[10px] font-pixel text-[8px] leading-[1.5] tracking-[0.04em] text-[#0b0820]"
          style="box-shadow:3px 3px 0 rgba(0,0,0,0.4)"
          data-cmd={pastePrompt}
        >
          COPY
        </button>
      </div>
    </div>

    <!-- content + sidebar -->
    <div class="detail-grid mt-[34px] grid grid-cols-[1fr_318px] items-start gap-9 max-md:grid-cols-1">
      <div class="md min-w-0" set:html={readmeHtml} />

      <aside class="flex flex-col gap-4">
        <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
          <div class="mb-[14px] flex items-center justify-between gap-3">
            <div class="font-pixel text-[8px] tracking-[0.06em] text-dim">ABOUT</div>
            <a href={sourceUrl} class="font-mono text-[11px] text-muted transition-colors hover:text-green">
              Source ↗
            </a>
          </div>
          <div class="flex flex-col gap-[11px] text-[13px]">
            {
              about.map((row) => (
                <div class="flex justify-between gap-3">
                  <span class="text-muted2">{row.k}</span>
                  <span
                    class="text-right font-mono text-[12px]"
                    style={row.accent ? "color:#54f0a8" : "color:#efe9ff"}
                  >
                    {row.v}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        {
          integrations.length > 0 && (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-[14px] font-pixel text-[8px] tracking-[0.06em] text-dim">
                INTEGRATIONS
              </div>
              <div class="flex flex-wrap gap-[7px]">
                {integrations.map((s) => (
                  <span class="border-2 border-edge bg-bg px-[9px] py-[5px] font-mono text-[11.5px] text-ink2">
                    {prettify(s)}
                  </span>
                ))}
              </div>
            </div>
          )
        }

        {
          variants.length > 0 ? (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-1 font-pixel text-[8px] tracking-[0.06em] text-dim">
                MORE {prettify(item.category).toUpperCase()} AGENTS
              </div>
              {variants.map((v) => (
                <a
                  href={`/agents/${v.name}/`}
                  class="flex items-center gap-[10px] border-t-2 border-edgedim py-[11px]"
                >
                  <span class="h-[9px] w-[9px] flex-none" style={`background:${color}`} />
                  <span class="flex-1 text-[13px] text-ink2">{v.title}</span>
                  <span class="whitespace-nowrap font-mono text-[11px] text-dim">→</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-[10px] font-pixel text-[8px] tracking-[0.06em] text-dim">
                REQUIRED ENV
              </div>
              {requiredEnv.length > 0 ? (
                requiredEnv.map((e) => (
                  <div class="flex items-center justify-between border-t-2 border-edgedim py-[9px]">
                    <span class="font-mono text-[12px] text-green">{e}</span>
                    <span class="font-mono text-[11px] text-dim">required</span>
                  </div>
                ))
              ) : (
                <div class="text-[13px] text-muted">No keys required.</div>
              )}
            </div>
          )
        }
      </aside>
    </div>
  </div>

  <Footer />
</Base>
