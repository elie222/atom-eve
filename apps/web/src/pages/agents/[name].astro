---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Glyph from "../../components/Glyph.astro";
import InstallBox from "../../components/InstallBox.tsx";
import CodeBrowser from "../../components/CodeBrowser.tsx";
import { getAgentFiles, getItems, getReadmeHtml, variantsOf, type AgentTargetFiles, type RegistryItem } from "../../lib/data";
import { catGlyph, famColor, installTargets, prettify, REPO, NEWSLETTER_URL } from "../../lib/format";

export async function getStaticPaths() {
  const items = getItems();
  return Promise.all(
    items.map(async (item) => ({
      params: { name: item.name },
      props: {
        item,
        readmeHtml: getReadmeHtml(item),
        agentFiles: await getAgentFiles(item),
        variants: variantsOf(item, items).map((v) => ({
          name: v.name,
          title: v.title,
        })),
      },
    })),
  );
}

interface Props {
  item: RegistryItem;
  readmeHtml: string;
  agentFiles: AgentTargetFiles[];
  variants: { name: string; title: string }[];
}

const { item, readmeHtml, agentFiles, variants } = Astro.props as Props;

const fileCount = agentFiles.reduce((max, t) => Math.max(max, t.files.length), 0);
const hasCode = fileCount > 0;

const color = famColor(item.family);
const glyph = catGlyph(item.category);
const frameworks = installTargets(item.targets);
const integrations = item.integrations ?? [];
const requiredEnv = item.requiredEnv ?? [];

// "Paste into your agent" prompt for this specific agent.
const promptName = item.title.toLowerCase().endsWith("agent") ? item.title : `${item.title} agent`;
const pastePrompt = `Read atomeve.dev/start.md and set up ${promptName} in my project.`;

const about: { k: string; v: string; accent?: boolean }[] = [
  { k: "Category", v: `${prettify(item.family)} / ${prettify(item.category)}` },
  { k: "Frameworks", v: frameworks.join(" · ") },
  { k: "Version", v: `v${item.version}` },
  { k: "State", v: item.memory ? "Memory" : "Stateless", accent: item.memory },
  { k: "Scheduled", v: item.scheduled ? "Yes" : "No" },
];
const sourceUrl = `${REPO}/tree/main/${item.repoPath}`;
const pageUrl = `https://www.atomeve.dev/agents/${item.name}/`;

// JSON-LD: describe the agent as installable software + a breadcrumb trail
// back to the registry, so result snippets show the path and app metadata.
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: item.title,
    description: item.description,
    url: pageUrl,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    softwareVersion: item.version,
    isAccessibleForFree: true,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    author: { "@type": "Organization", name: "Atom Eve", url: "https://www.atomeve.dev/" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Agents", item: "https://www.atomeve.dev/" },
      { "@type": "ListItem", position: 2, name: item.title, item: pageUrl },
    ],
  },
];
---

<Base
  title={`${item.title} — Atom Eve`}
  description={item.description}
  type="article"
  imageAlt={`${item.title} — an installable AI agent on Atom Eve`}
  structuredData={structuredData}
>
  <Nav variant="detail" />

  <div class="relative z-[2] mx-auto max-w-[1200px] px-[30px] pb-20 pt-[30px] max-sm:px-4">
    <!-- header -->
    <div class="flex flex-wrap items-start gap-[18px]">
      <div
        class="flex h-[56px] w-[56px] flex-none items-center justify-center"
        style={`background:${color}1f;border:2px solid ${color}4d`}
      >
        <Glyph glyph={glyph} color={color} scale={5} />
      </div>
      <div class="min-w-[280px] flex-1">
        <h1 class="m-0 text-[34px] font-bold leading-[1.08]">{item.title}</h1>
        <div class="mt-[10px] text-[16.5px] text-ink2">{item.description}</div>
      </div>
    </div>

    <div
      class="mt-[26px] border-2 border-edge bg-code"
      style="box-shadow:4px 4px 0 rgba(0,0,0,0.35)"
    >
      <div class="flex items-center gap-2 border-b-2 border-edgedim px-4 py-[10px]">
        <span class="font-pixel text-[8px] tracking-[0.06em] text-dim"
          >PASTE INTO YOUR AGENT</span
        >
      </div>
      <div class="flex items-center gap-[14px] px-[18px] py-[14px]">
        <code
          class="min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap font-mono text-[13px] text-ink2"
          ><span class="text-cyan">▸</span> {pastePrompt}</code
        >
        <button
          type="button"
          class="copy-btn arcade-btn flex-none whitespace-nowrap bg-cyan px-[13px] py-[10px] font-pixel text-[8px] leading-[1.5] tracking-[0.04em] text-[#0b0820]"
          style="box-shadow:3px 3px 0 rgba(0,0,0,0.4)"
          data-cmd={pastePrompt}
        >
          COPY
        </button>
      </div>
    </div>

    <InstallBox client:load name={item.name} targets={item.targets ?? []} />

    <!-- content + sidebar -->
    <div class="detail-grid mt-[34px] grid grid-cols-[1fr_318px] items-start gap-9 max-md:grid-cols-1">
      <div class="min-w-0">
        {
          hasCode && (
            <div class="mb-5 flex border-2 border-edge bg-bg" role="tablist" aria-label="View">
              <button
                type="button"
                role="tab"
                id="tab-btn-readme"
                aria-selected="true"
                data-panel="readme"
                class="detail-tab cursor-pointer border-r-2 border-edge px-4 py-[8px] font-pixel text-[8px] tracking-[0.06em] transition-colors"
              >
                README
              </button>
              <button
                type="button"
                role="tab"
                id="tab-btn-code"
                aria-selected="false"
                data-panel="code"
                class="detail-tab cursor-pointer px-4 py-[8px] font-pixel text-[8px] tracking-[0.06em] transition-colors"
              >
                CODE
              </button>
            </div>
          )
        }

        <div id="panel-readme" class="md" set:html={readmeHtml} />

        {
          hasCode && (
            <div id="panel-code" hidden>
              <p class="mb-4 text-[14px] text-ink2">
                The exact source <code class="font-mono text-[13px] text-green">npx atom-eve add</code> installs —
                instructions, tools, and skills. Read it here, or copy any file straight into your project.
              </p>
              <CodeBrowser client:load targets={agentFiles} />
            </div>
          )
        }
      </div>

      <aside class="flex flex-col gap-4">
        {
          integrations.length > 0 && (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-[14px] font-pixel text-[8px] tracking-[0.06em] text-dim">
                INTEGRATIONS
              </div>
              <div class="flex flex-wrap gap-[7px]">
                {integrations.map((s) => (
                  <span class="border-2 border-edge bg-bg px-[9px] py-[5px] font-mono text-[11.5px] text-ink2">
                    {prettify(s)}
                  </span>
                ))}
              </div>
            </div>
          )
        }

        {
          variants.length > 0 ? (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-1 font-pixel text-[8px] tracking-[0.06em] text-dim">
                MORE {prettify(item.category).toUpperCase()} AGENTS
              </div>
              {variants.map((v) => (
                <a
                  href={`/agents/${v.name}/`}
                  class="flex items-center gap-[10px] border-t-2 border-edgedim py-[11px]"
                >
                  <span class="h-[9px] w-[9px] flex-none" style={`background:${color}`} />
                  <span class="flex-1 text-[13px] text-ink2">{v.title}</span>
                  <span class="whitespace-nowrap font-mono text-[11px] text-dim">→</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
              <div class="mb-[10px] font-pixel text-[8px] tracking-[0.06em] text-dim">
                REQUIRED ENV
              </div>
              {requiredEnv.length > 0 ? (
                requiredEnv.map((e) => (
                  <div class="flex items-center justify-between border-t-2 border-edgedim py-[9px]">
                    <span class="font-mono text-[12px] text-green">{e}</span>
                    <span class="font-mono text-[11px] text-dim">required</span>
                  </div>
                ))
              ) : (
                <div class="text-[13px] text-muted">No keys required.</div>
              )}
            </div>
          )
        }

        <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
          <div class="mb-[14px] flex items-center justify-between gap-3">
            <div class="font-pixel text-[8px] tracking-[0.06em] text-dim">ABOUT</div>
            <a href={sourceUrl} class="font-mono text-[11px] text-muted transition-colors hover:text-green">
              Source ↗
            </a>
          </div>
          <div class="flex flex-col gap-[11px] text-[13px]">
            {
              about.map((row) => (
                <div class="flex justify-between gap-3">
                  <span class="text-muted2">{row.k}</span>
                  <span
                    class="text-right font-mono text-[12px]"
                    style={row.accent ? "color:#54f0a8" : "color:#efe9ff"}
                  >
                    {row.v}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="border-2 border-edge bg-panel p-4 shadow-[4px_4px_0_rgba(0,0,0,0.25)]">
          <div class="mb-[10px] font-pixel text-[8px] tracking-[0.06em] text-pink">NEW DROPS</div>
          <p class="mb-[14px] text-[13px] leading-[1.55] text-muted">
            Get an email when we ship new agents.
          </p>
          <a
            href={NEWSLETTER_URL}
            target="_blank"
            rel="noopener"
            class="arcade-btn inline-block whitespace-nowrap bg-pink px-[14px] py-[10px] font-pixel text-[8px] leading-[1.5] tracking-[0.04em] text-[#0b0820] shadow-[3px_3px_0_#8a1668]"
          >
            NOTIFY ME ▸
          </a>
        </div>
      </aside>
    </div>
  </div>

  <Footer />

  <script>
    // README / Code tab toggle on the detail page (progressive enhancement).
    (() => {
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>(".detail-tab"));
      if (!buttons.length) return;
      const panels: Record<string, HTMLElement | null> = {
        readme: document.getElementById("panel-readme"),
        code: document.getElementById("panel-code"),
      };
      const select = (name: string) => {
        for (const btn of buttons) btn.setAttribute("aria-selected", String(btn.dataset.panel === name));
        for (const [key, el] of Object.entries(panels)) el && (el.hidden = key !== name);
      };
      for (const btn of buttons) btn.addEventListener("click", () => select(btn.dataset.panel ?? "readme"));
      if (location.hash === "#code") select("code");
    })();
  </script>
</Base>
