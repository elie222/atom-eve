---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AgentCard from "../components/AgentCard.astro";
import HeroFigure from "../components/HeroFigure.astro";
import { getItems, getTaxonomy, toCard, familyCounts, getManifest } from "../lib/data";
import { FAM, famColor, highlightJson, prettify, REPO } from "../lib/format";

const items = getItems();
const taxonomy = getTaxonomy();
const cards = items.map(toCard);
const counts = familyCounts(items);
const total = items.length;

const manifestExample =
  items.length > 0
    ? getManifest(items[0])
    : {
        name: "SEO Improver",
        category: "growth/seo",
        description: "Search Console + rewrite",
        integrations: ["search-console", "openai"],
        memory: true,
        scheduled: true,
        version: "1.2.0",
        requiredEnv: ["GSC_KEY", "OPENAI_API_KEY"],
      };

const steps = [
  { no: "01", title: "Fork an agent", body: "Grab any variant — a full eve.dev / flue agent in one folder.", color: FAM.growth },
  { no: "02", title: "Add your keys", body: "Every atom declares the keys it needs in atom.json.", color: FAM.engineering },
  { no: "03", title: "Deploy", body: "Ship it on eve.dev or flue. Same flow for every agent.", color: FAM.revenue },
];

const stats = ["MIT licensed", "Fork any agent", "Manifest-driven (atom.json)", "Open source on GitHub"];
const publishSteps = [
  { n: "1", color: FAM.growth, text: "Fork the agent template" },
  { n: "2", color: FAM.engineering, text: "Drop in your atom.json" },
  { n: "3", color: FAM.revenue, text: "Open a PR — auto-listed on merge" },
];
---

<Base
  title="Atom Eve — an agent for every job"
  description="An open-source, shadcn-style registry of installable AI agents for eve.dev and flue."
>
  <Nav />

  <!-- hero -->
  <section class="mx-auto max-w-[720px] px-8 pb-16 pt-[84px] text-center">
    <div class="font-pixel text-[10px] tracking-[0.12em] text-eve">▸ OPEN-SOURCE AGENT REGISTRY</div>
    <h1 class="mt-[26px] text-[58px] font-bold leading-none tracking-[-0.025em] max-sm:text-[40px]">
      An agent for every job.
    </h1>
    <p class="mx-auto mt-5 max-w-[540px] text-[18px] leading-[1.55] text-muted">
      Open-source agents for eve.dev and flue. Find one, add your keys, ship it.
    </p>
    <label
      class="mx-auto mt-[34px] flex max-w-[560px] cursor-text items-center gap-[11px] rounded-[10px] border border-edge2 bg-panel px-[17px] py-[15px]"
    >
      <span class="font-pixel text-[10px] text-eve">▸</span>
      <input
        id="hero-search"
        placeholder={'Search agents — "seo", "ads", "qa"…'}
        class="flex-1 border-none bg-transparent text-left font-mono text-[14px] text-ink outline-none"
      />
      <span class="animate-blink inline-block h-[17px] w-2 bg-eve"></span>
    </label>
    <div class="mt-[22px] flex flex-wrap justify-center gap-[11px]">
      <a
        href="#registry"
        class="whitespace-nowrap rounded-md bg-eve px-[22px] py-[13px] text-[14px] font-semibold text-[#0a0a0c] transition-[filter] hover:brightness-[1.08]"
        >Install your first agent</a
      >
      <a
        href={REPO}
        class="whitespace-nowrap rounded-md border border-edge2 px-5 py-[13px] text-[14px] font-semibold text-ink transition-colors hover:bg-panel2"
        >★ Get started on GitHub</a
      >
    </div>
  </section>

  <!-- stats bar -->
  <div class="border-y border-edge bg-bg2">
    <div
      class="mx-auto flex max-w-[1180px] flex-wrap justify-between gap-[14px] px-8 py-4 font-mono text-[13px] text-muted"
    >
      {stats.map((s) => <span><span class="text-eve">▪</span>&nbsp; {s}</span>)}
    </div>
  </div>

  <!-- how it works -->
  <section class="mx-auto max-w-[1180px] px-8 pt-[54px]">
    <div class="font-mono text-[11px] tracking-[0.08em] text-eve">// how it works</div>
    <div class="mt-3 font-pixel text-[17px]">THREE STEPS TO SHIP</div>
    <div class="mt-[22px] grid grid-cols-1 gap-[14px] sm:grid-cols-3">
      {
        steps.map((s) => (
          <div class="rounded-lg border border-edge bg-panel p-5">
            <div class="font-pixel text-[15px]" style={`color:${s.color}`}>
              {s.no}
            </div>
            <div class="mt-[14px] text-[16.5px] font-semibold">{s.title}</div>
            <div class="mt-2 text-[14.5px] leading-[1.55] text-muted">{s.body}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- the registry -->
  <section id="registry" class="mx-auto max-w-[1180px] px-8 pt-[54px]">
    <div class="font-mono text-[11px] tracking-[0.08em] text-eve">// the registry</div>
    <div class="mt-3 flex flex-wrap items-end justify-between gap-5">
      <div class="font-pixel text-[17px]">PICK AN AGENT</div>
      <div class="max-w-[560px] text-[14.5px] leading-[1.55] text-muted">
        Every agent is a folder + an <span class="font-mono text-[13px] text-eve">atom.json</span> manifest
        declaring what it does and the keys it needs. Copy, configure, ship.
      </div>
    </div>

    <div class="reg-layout mt-[26px] flex items-start gap-8 max-md:flex-col">
      <aside id="categories" class="reg-rail w-[212px] flex-none max-md:w-full">
        <div class="mb-3 font-mono text-[11px] tracking-[0.08em] text-dim">CATEGORIES</div>
        <button
          type="button"
          data-family="all"
          aria-pressed="true"
          class="cat-btn active mb-[6px] flex w-full items-center justify-between rounded-[7px] border border-transparent px-[11px] py-[9px] text-left"
        >
          <span class="text-[14px] font-semibold text-ink">All agents</span>
          <span class="font-mono text-[11.5px] text-eve">{total}</span>
        </button>
        {
          taxonomy.families.map((family) => (
            <button
              type="button"
              data-family={family}
              aria-pressed="false"
              class="cat-btn flex w-full items-center justify-between rounded-[7px] border border-transparent px-[11px] py-[9px] text-left"
            >
              <span class="flex items-center gap-[9px]">
                <span
                  class="h-[9px] w-[9px] flex-none rounded-[2px]"
                  style={`background:${famColor(family)}`}
                />
                <span class="text-[14px] text-ink2">{prettify(family)}</span>
              </span>
              <span class="cat-count font-mono text-[11.5px] text-dim">{counts[family] ?? 0}</span>
            </button>
          ))
        }
      </aside>

      <div class="min-w-0 flex-1">
        <div
          id="agent-grid"
          class="grid gap-[14px] [grid-template-columns:repeat(auto-fill,minmax(230px,1fr))]"
        >
          {cards.map((agent) => <AgentCard agent={agent} />)}
        </div>
        <p id="no-results" class="hidden py-10 text-center font-mono text-[13px] text-muted">
          No agents match that search.
        </p>
      </div>
    </div>
  </section>

  <!-- publish your own -->
  <section id="publish" class="mx-auto max-w-[1180px] px-8 py-[60px]">
    <div class="publish-grid grid grid-cols-[1fr_480px] items-start gap-12 max-md:grid-cols-1">
      <div>
        <div class="font-mono text-[11px] tracking-[0.08em] text-eve">// open source</div>
        <div class="mt-3 font-pixel text-[17px] leading-[1.5]">PUBLISH<br />YOUR OWN</div>
        <p class="mt-[18px] max-w-[480px] text-[15.5px] leading-[1.6] text-muted">
          It's all open source. Every agent is a folder + an <span
            class="font-mono text-[13.5px] text-ink">atom.json</span
          > manifest that declares what it does and what keys it needs. Add yours, open a PR, and the
          registry updates itself — same copy-and-configure flow for everyone.
        </p>
        <div class="mt-[22px] flex flex-col gap-[10px]">
          {
            publishSteps.map((p) => (
              <div class="flex items-center gap-[11px]">
                <span class="font-pixel text-[10px]" style={`color:${p.color}`}>
                  {p.n}
                </span>
                <span class="text-[14px] text-ink2">{p.text}</span>
              </div>
            ))
          }
        </div>
        <div class="mt-[26px] flex gap-[10px]">
          <a
            href={REPO}
            class="rounded-md bg-eve px-5 py-3 text-[14px] font-semibold text-[#0a0a0c] transition-[filter] hover:brightness-[1.08]"
            >Read the guide</a
          >
          <a
            href={REPO}
            class="rounded-md border border-edge px-[18px] py-3 text-[14px] font-semibold text-ink transition-colors hover:bg-panel2"
            >Use the template</a
          >
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div
          class="relative flex h-[228px] items-center justify-center overflow-hidden rounded-[10px] border border-edge"
          style="background:radial-gradient(ellipse 70% 60% at 50% 42%, rgba(155,255,92,0.12), rgba(0,0,0,0) 70%), #0a0d1a"
        >
          <div
            class="absolute bottom-[44px] left-[34px] right-[34px] h-[22px] rounded-[50%]"
            style="background:radial-gradient(ellipse at center, rgba(155,255,92,0.18), rgba(0,0,0,0) 70%)"
          >
          </div>
          <div class="animate-bob mb-[30px]"><HeroFigure /></div>
          <div
            class="pointer-events-none absolute inset-0"
            style="background:repeating-linear-gradient(0deg,rgba(0,0,0,0) 0px,rgba(0,0,0,0) 2px,rgba(0,0,0,0.32) 3px)"
          >
          </div>
          <div class="absolute bottom-3 left-4 font-mono text-[10px]" style="color:#5a618a">
            // your agent joins the roster
          </div>
        </div>
        <div class="overflow-hidden rounded-[10px] border border-edge bg-code">
          <div class="flex items-center gap-[7px] border-b border-edge px-[15px] py-3">
            <span class="h-[11px] w-[11px] rounded-full bg-sup"></span>
            <span class="h-[11px] w-[11px] rounded-full bg-rev"></span>
            <span class="h-[11px] w-[11px] rounded-full bg-eve"></span>
            <span class="ml-2 font-mono text-[11px] text-dim">atom.json</span>
          </div>
          <pre
            class="m-0 overflow-x-auto p-[18px] font-mono text-[12.5px] leading-[1.7] text-ink2"
            set:html={highlightJson(manifestExample)}
          />
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    const search = document.getElementById("hero-search") as HTMLInputElement | null;
    const grid = document.getElementById("agent-grid");
    const empty = document.getElementById("no-results");
    const catButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".cat-btn"),
    );

    if (grid) {
      const cards = Array.from(grid.querySelectorAll<HTMLElement>(".agent-card"));
      let activeFamily = "all";

      const apply = () => {
        const q = (search?.value ?? "").trim().toLowerCase();
        let shown = 0;
        for (const card of cards) {
          const matchSearch = !q || (card.textContent ?? "").toLowerCase().includes(q);
          const matchFamily = activeFamily === "all" || card.dataset.family === activeFamily;
          const visible = matchSearch && matchFamily;
          card.style.display = visible ? "flex" : "none";
          if (visible) shown++;
        }
        if (empty) empty.classList.toggle("hidden", shown !== 0);
      };

      search?.addEventListener("input", apply);

      for (const btn of catButtons) {
        btn.addEventListener("click", () => {
          activeFamily = btn.dataset.family ?? "all";
          for (const b of catButtons) {
            const on = b === btn;
            b.classList.toggle("active", on);
            b.setAttribute("aria-pressed", String(on));
          }
          apply();
        });
      }
    }
  </script>
</Base>
