---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AgentCard from "../components/AgentCard.astro";
import AgentRow from "../components/AgentRow.astro";
import { getItems, getTaxonomy, toCard, familyCounts } from "../lib/data";
import { famColor, prettify, REPO, X_PROFILE } from "../lib/format";

const items = getItems();
const taxonomy = getTaxonomy();
const cards = items.map(toCard);
const counts = familyCounts(items);
const total = items.length;

// Get Started modal: curated starter agents. Filtered against the live registry
// so a renamed slug never renders a dead chip. Picking one rewrites both commands.
const STARTERS = [
  { slug: "website-qa", label: "Product QA", tag: "Tests your signup and checkout flows for breaks." },
  { slug: "seo-audit", label: "SEO Fixes", tag: "Finds what's hurting your rankings, worst first." },
  { slug: "stripe-pulse", label: "Stripe Revenue", tag: "Weekly revenue and churn alerts, posted to Slack." },
  { slug: "research-assistant", label: "Research Assistant", tag: "Turns a question into a cited, decision-ready brief." },
].filter((s) => items.some((it) => it.name === s.slug));
const START = STARTERS[0]!;
const startPrompt = `Read atomeve.dev/start.md and add the ${START.label} agent.`;
const startCli = `npx atom-eve init\nnpx atom-eve add ${START.slug}`;

// Deterministic starfield behind the hero (seeded so static output is stable).
// One 2px dot whose box-shadow paints `n` stars across a centered canvas.
function starfield(n: number, w: number, h: number, cols: string[]): string {
  let r = 987654321;
  const rnd = () => {
    r = (r * 1103515245 + 12345) & 0x7fffffff;
    return r / 0x7fffffff;
  };
  const stars: string[] = [];
  for (let i = 0; i < n; i++) {
    const x = Math.round((rnd() - 0.5) * w);
    const y = Math.round(rnd() * h);
    const c = cols[Math.floor(rnd() * cols.length)];
    stars.push(`${x}px ${y}px 0 0 ${c}`);
  }
  return stars.join(",");
}
const HERO_STARS = starfield(120, 1280, 470, ["#ffffff", "#37d6ff", "#ff45c2", "#a974ff", "#cfc4ff"]);

const metaDescription = `Atom Eve is an open-source, shadcn-style registry of ${total} installable AI agents for eve and Flue projects — SEO, ads, QA, support, and more. Drop them straight into your project with one command.`;

// JSON-LD: identify the site (with on-site search) and the org behind it so
// search engines can surface a sitelinks search box and brand entity.
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Atom Eve",
    url: "https://www.atomeve.dev/",
    description: metaDescription,
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: "https://www.atomeve.dev/?q={search_term_string}",
      },
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Atom Eve",
    url: "https://www.atomeve.dev/",
    logo: "https://www.atomeve.dev/android-chrome-512x512.png",
    sameAs: [REPO, X_PROFILE],
  },
];
---

<Base
  title="Atom Eve — an agent for every job"
  description={metaDescription}
  imageAlt="Atom Eve — an open-source registry of installable AI agents for eve and Flue"
  structuredData={structuredData}
>
  <Nav variant="landing" />

  <!-- hero -->
  <section class="relative z-[2] mx-auto max-w-[1100px] overflow-hidden px-8 pb-7 pt-[46px] text-center">
    <div
      class="pointer-events-none absolute left-1/2 top-[18px] z-0 h-[2px] w-[2px]"
      style={`box-shadow:${HERO_STARS};opacity:0.8`}
      aria-hidden="true"
    >
    </div>
    <div class="relative z-[1]">
    <div class="font-pixel text-[11px] leading-[1.6] tracking-[0.16em] text-cyan">
      ▸ OPEN-SOURCE AGENT REGISTRY
    </div>

    <!-- top banner image -->
    <div
      class="relative mx-auto mt-[22px] max-w-[900px] border-2 border-edge2 bg-code p-[9px]"
      style="box-shadow:0 0 0 2px #0b0820, 0 0 56px rgba(255,69,194,0.24), 9px 9px 0 rgba(0,0,0,0.45)"
    >
      <div class="hero-img-wrap relative overflow-hidden">
        <img
          src="/atom-eve-og.png"
          alt="Atom Eve"
          class="block w-full"
          style="image-rendering:pixelated"
        />
        <div
          class="pointer-events-none absolute inset-0"
          style="background:repeating-linear-gradient(0deg,rgba(0,0,0,0) 0px,rgba(0,0,0,0) 2px,rgba(0,0,0,0.30) 3px)"
          aria-hidden="true"
        >
        </div>
        <div class="hero-sweep" aria-hidden="true"></div>
      </div>
      <span class="absolute -left-[5px] -top-[5px] h-[9px] w-[9px] bg-pink"></span>
      <span class="absolute -right-[5px] -top-[5px] h-[9px] w-[9px] bg-cyan"></span>
      <span class="absolute -bottom-[5px] -left-[5px] h-[9px] w-[9px] bg-cyan"></span>
      <span class="absolute -bottom-[5px] -right-[5px] h-[9px] w-[9px] bg-pink"></span>
    </div>

    <p class="mx-auto mt-6 max-w-[690px] text-[21px] leading-[1.55] text-ink2">
      Open-source AI agents for <span class="text-cyan">eve</span> and{" "}
      <span class="text-green">Flue</span> projects.<br />
      Production-ready agents to build and grow your business.
    </p>

    <div class="mt-7 flex flex-wrap items-center justify-center gap-[13px]">
      <button
        type="button"
        data-open-modal
        class="arcade-btn bg-pink px-[26px] py-[17px] font-pixel text-[12px] leading-[1.5] tracking-[0.03em] text-[#0b0820] shadow-[6px_6px_0_#8a1668]"
      >
        GET STARTED ▸
      </button>
      <a
        href={REPO}
        class="arcade-btn border-2 border-cyan px-5 py-[15px] font-pixel text-[11px] leading-[1.5] tracking-[0.03em] text-cyan shadow-[6px_6px_0_rgba(55,214,255,0.22)]"
      >
        ★ GITHUB
      </a>
    </div>
    </div>
  </section>

  <!-- browse: search + tabs + view toggle -->
  <section id="registry" class="relative z-[3] mx-auto mt-[22px] max-w-[1200px] px-8">
    <!-- search — filters the registry below -->
    <label
      id="categories"
      class="flex cursor-text items-center gap-[10px] border-2 border-edge2 bg-bg2 px-4 py-3 shadow-[3px_3px_0_rgba(0,0,0,0.3)]"
    >
      <span class="font-mono text-[13px] text-dim">/</span>
      <input
        id="agent-search"
        placeholder="Search agents…"
        class="flex-1 border-none bg-transparent text-left font-mono text-[13px] tracking-[0.02em] text-ink outline-none"
      />
      <span class="animate-blink inline-block h-[16px] w-2 bg-cyan"></span>
    </label>

    <div
      class="mt-4 flex flex-wrap items-center justify-between gap-4 border-b-2 border-edge pb-4"
    >
      <!-- category tabs -->
      <div class="cat-bar -mx-1 flex items-center gap-[9px] overflow-x-auto px-1 pb-1">
        <button
          type="button"
          data-family="all"
          aria-pressed="true"
          class="cat-pill active inline-flex flex-none items-center gap-[8px] border-2 border-edge px-3 py-2 font-mono text-[12px] font-semibold text-ink2"
          style="--fam:#ff45c2"
        >
          ALL
          <span class="cat-count font-mono text-[11px] opacity-55">{total}</span>
        </button>
        {
          taxonomy.families.map((family) => (
            <button
              type="button"
              data-family={family}
              aria-pressed="false"
              class="cat-pill inline-flex flex-none items-center gap-[8px] border-2 border-edge px-3 py-2 font-mono text-[12px] font-semibold text-ink2"
              style={`--fam:${famColor(family)}`}
            >
              {prettify(family).toUpperCase()}
              <span class="cat-count font-mono text-[11px] opacity-55">{counts[family] ?? 0}</span>
            </button>
          ))
        }
      </div>

      <!-- view toggle -->
      <div class="flex flex-none items-center gap-[7px]" role="group" aria-label="View">
        <button
          type="button"
          data-view-btn="grid"
          aria-pressed="true"
          class="view-btn active inline-flex items-center gap-[6px] border-2 border-edge px-[11px] py-[7px] font-mono text-[11px] font-semibold text-muted"
        >
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="6" height="6" rx="1.2" fill="currentColor"></rect>
            <rect x="9" y="1" width="6" height="6" rx="1.2" fill="currentColor"></rect>
            <rect x="1" y="9" width="6" height="6" rx="1.2" fill="currentColor"></rect>
            <rect x="9" y="9" width="6" height="6" rx="1.2" fill="currentColor"></rect>
          </svg>
          GRID
        </button>
        <button
          type="button"
          data-view-btn="list"
          aria-pressed="false"
          class="view-btn inline-flex items-center gap-[6px] border-2 border-edge px-[11px] py-[7px] font-mono text-[11px] font-semibold text-muted"
        >
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="1" y="2" width="14" height="2.4" rx="1.2" fill="currentColor"></rect>
            <rect x="1" y="6.8" width="14" height="2.4" rx="1.2" fill="currentColor"></rect>
            <rect x="1" y="11.6" width="14" height="2.4" rx="1.2" fill="currentColor"></rect>
          </svg>
          LIST
        </button>
      </div>
    </div>

    <!-- registry -->
    <div id="registry-views" data-view="grid" class="mt-[22px]">
      <div
        id="agent-grid"
        class="grid gap-4 [grid-template-columns:repeat(3,1fr)] max-lg:[grid-template-columns:repeat(2,1fr)] max-sm:grid-cols-1"
      >
        {cards.map((agent) => <AgentCard agent={agent} />)}
      </div>
      <div id="agent-list" class="flex flex-col gap-[10px]">
        {cards.map((agent) => <AgentRow agent={agent} />)}
      </div>
      <p id="no-results" class="hidden py-10 text-center font-mono text-[13px] text-muted">
        No agents match that search.
      </p>
    </div>
  </section>

  <!-- bottom banner — lifted above the scanline overlay (z-100) so the graphic stays legible -->
  <section class="relative z-[110] mx-auto mt-16 max-w-[1200px] px-8">
    <div class="font-mono text-[11px] tracking-[0.08em] text-cyan">// built for every team</div>
    <div class="mt-3 font-pixel text-[16px] leading-[1.5]">ONE REGISTRY, EVERY TEAM</div>
    <div
      class="relative mt-6 border-2 border-edge2 bg-code p-[9px]"
      style="box-shadow:0 0 0 2px #0b0820, 0 0 48px rgba(55,214,255,0.14), 8px 8px 0 rgba(0,0,0,0.45)"
    >
      <img
        src="/atom-eve-install.png"
        alt="Atom Eve agents overview"
        class="block w-full"
        style="image-rendering:pixelated"
      />
      <span class="absolute -left-[5px] -top-[5px] h-[9px] w-[9px] bg-cyan"></span>
      <span class="absolute -right-[5px] -top-[5px] h-[9px] w-[9px] bg-pink"></span>
      <span class="absolute -bottom-[5px] -left-[5px] h-[9px] w-[9px] bg-pink"></span>
      <span class="absolute -bottom-[5px] -right-[5px] h-[9px] w-[9px] bg-cyan"></span>
    </div>
  </section>

  <!-- publish band -->
  <section id="publish" class="relative z-[2] mx-auto mt-9 max-w-[1200px] px-8">
    <div
      class="flex flex-wrap items-center justify-between gap-[30px] border-2 border-edge bg-panel p-[30px] shadow-[6px_6px_0_rgba(0,0,0,0.3)]"
    >
      <div class="max-w-[560px]">
        <div class="font-mono text-[11px] tracking-[0.08em] text-green">// open source</div>
        <div class="mt-3 font-pixel text-[15px] leading-[1.5]">PUBLISH YOUR OWN</div>
        <p class="mt-[14px] text-[14.5px] leading-[1.6] text-muted">
          Every agent is a folder + an <span class="font-mono text-[13px] text-ink">atom.json</span>
          manifest. Fork the template, open a PR, and it's auto-listed on merge.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href={REPO}
          class="arcade-btn bg-green px-[17px] py-[13px] font-pixel text-[10px] leading-[1.5] tracking-[0.02em] text-[#0b0820] shadow-[4px_4px_0_#1d7a4e]"
        >
          READ THE GUIDE
        </a>
        <a
          href={REPO}
          class="border-2 border-edge px-[15px] py-[11px] font-pixel text-[10px] leading-[1.5] tracking-[0.02em] text-ink transition-colors hover:border-green hover:text-green"
        >
          USE TEMPLATE
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- get started modal -->
  <div
    id="get-started-modal"
    class="modal-overlay fixed inset-0 z-[200] items-center justify-center bg-[rgba(5,3,15,0.82)] p-6"
    data-close-modal
  >
    <div
      class="relative max-h-[90vh] w-[min(620px,100%)] overflow-auto border-2 border-edge2 bg-panel shadow-[9px_9px_0_rgba(0,0,0,0.5)]"
    >
      <div class="flex items-center justify-between gap-3 border-b-2 border-edge px-5 py-[18px]">
        <div class="font-pixel text-[13px]">
          <span class="text-pink">GET</span> <span class="text-cyan">STARTED</span>
        </div>
        <button
          type="button"
          data-close-modal
          aria-label="Close"
          class="cursor-pointer border-2 border-edge bg-transparent px-[10px] py-[7px] font-pixel text-[11px] leading-none text-muted transition-colors hover:border-pink hover:text-pink"
        >
          ✕
        </button>
      </div>
      <div class="p-5">
        <p class="m-0 text-[15px] leading-[1.6] text-ink2">
          Add an agent to your project, yours to edit and deploy.
        </p>

        <!-- pick an agent -->
        <div class="mt-[18px]">
          <div class="mb-[10px] flex items-baseline justify-between gap-3">
            <span class="font-pixel text-[8px] tracking-[0.06em] text-dim">PICK AN AGENT</span>
            <a
              href="#registry-views"
              data-close-modal
              class="font-mono text-[12px] text-muted2 transition-colors hover:text-cyan"
            >
              Browse all agents →
            </a>
          </div>
          <div id="gs-agents" class="flex flex-wrap gap-[8px]">
            {
              STARTERS.map((a, i) => (
                <button
                  type="button"
                  class="gs-chip cursor-pointer border-2 border-edge bg-bg px-[11px] py-[6px] font-mono text-[12.5px] text-muted transition-colors hover:border-cyan hover:text-ink"
                  data-slug={a.slug}
                  data-label={a.label}
                  data-tag={a.tag}
                  aria-pressed={i === 0 ? "true" : "false"}
                >
                  {a.label}
                </button>
              ))
            }
          </div>
          <p id="gs-agent-tag" class="mt-[10px] text-[13px] leading-[1.5] text-muted">{START.tag}</p>
        </div>

        <!-- method 1: coding agent -->
        <div class="mt-[18px] border-2 border-edge bg-code">
          <div class="flex items-center gap-2 border-b-2 border-edgedim px-[14px] py-[11px]">
            <span class="font-pixel text-[9px] tracking-[0.04em] text-green">USE YOUR CODING AGENT</span
            >
          </div>
          <div class="px-[14px] py-[13px]">
            <div class="flex items-center gap-3">
              <code
                class="min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap font-mono text-[13.5px] text-ink2"
                ><span class="text-green">▸</span> Read atomeve.dev/start.md and add the <span
                  id="gs-prompt-name"
                  class="text-green">{START.label}</span
                > agent.</code
              >
              <button
                type="button"
                id="gs-prompt-copy"
                class="copy-btn arcade-btn flex-none whitespace-nowrap bg-green px-3 py-[10px] font-pixel text-[8px] leading-[1.5] tracking-[0.04em] text-[#0b0820] shadow-[3px_3px_0_rgba(0,0,0,0.4)]"
                data-cmd={startPrompt}
              >
                COPY
              </button>
            </div>
            <div class="mt-[11px] text-[13px] leading-[1.5] text-muted">
              Works in Claude Code, Cursor, or Codex.
            </div>
          </div>
        </div>

        <!-- method 2: cli -->
        <div class="mt-[14px] border-2 border-edge bg-code">
          <div
            class="flex items-center justify-between gap-3 border-b-2 border-edgedim px-[14px] py-[11px]"
          >
            <span class="font-pixel text-[9px] tracking-[0.04em] text-cyan">OR USE THE CLI</span>
            <div class="flex items-center gap-[8px]">
              <span class="font-pixel text-[8px] tracking-[0.06em] text-dim">TARGET</span>
              <div
                id="gs-target"
                class="flex border-2 border-edge bg-bg"
                role="tablist"
                aria-label="Install target"
              >
                <button
                  type="button"
                  role="tab"
                  data-target="eve"
                  aria-selected="true"
                  class="gs-target-btn cursor-pointer border-r-2 border-edge px-[10px] py-[4px] font-mono text-[12px] font-semibold text-muted"
                >
                  eve
                </button>
                <button
                  type="button"
                  role="tab"
                  data-target="flue"
                  aria-selected="false"
                  class="gs-target-btn cursor-pointer px-[10px] py-[4px] font-mono text-[12px] font-semibold text-muted"
                >
                  Flue
                </button>
              </div>
            </div>
          </div>
          <div class="px-[14px] py-[13px]">
            <div class="flex items-center gap-3">
              <div class="min-w-0 flex-1 font-mono text-[13.5px] leading-[1.7] text-ink2">
                <div class="overflow-hidden text-ellipsis whitespace-nowrap">
                  <span class="text-cyan">$</span> npx atom-eve init<span
                    id="gs-cli-target"
                    class="text-muted"></span>
                </div>
                <div class="overflow-hidden text-ellipsis whitespace-nowrap">
                  <span class="text-cyan">$</span> npx atom-eve add <span
                    id="gs-cli-slug"
                    class="text-cyan">{START.slug}</span
                  >
                </div>
              </div>
              <button
                type="button"
                id="gs-cli-copy"
                class="copy-btn arcade-btn flex-none whitespace-nowrap bg-cyan px-3 py-[10px] font-pixel text-[8px] leading-[1.5] tracking-[0.04em] text-[#0b0820] shadow-[3px_3px_0_rgba(0,0,0,0.4)]"
                data-cmd={startCli}
              >
                COPY
              </button>
            </div>
          </div>
        </div>

        <div class="mt-[18px] font-mono text-[13px] text-muted2">
          <a href={REPO} class="text-ink hover:text-cyan">Read the docs ↗</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ----- registry: search + category filter + grid/list view -----
    const wrap = document.getElementById("registry-views");
    const search = document.getElementById("agent-search") as HTMLInputElement | null;
    const empty = document.getElementById("no-results");
    const catButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".cat-pill"));
    const viewButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-view-btn]"));

    if (wrap) {
      // Each agent renders twice — once as a grid card, once as a list row.
      // Filtering toggles both copies; only one view is visible at a time.
      const items = Array.from(wrap.querySelectorAll<HTMLElement>(".agent-item"));
      let activeFamily = "all";

      const apply = () => {
        const q = (search?.value ?? "").trim().toLowerCase();
        let shown = 0;
        for (const el of items) {
          const matchSearch = !q || (el.textContent ?? "").toLowerCase().includes(q);
          const matchFamily = activeFamily === "all" || el.dataset.family === activeFamily;
          const visible = matchSearch && matchFamily;
          el.classList.toggle("is-hidden", !visible);
          if (visible && el.classList.contains("agent-card")) shown++;
        }
        wrap.classList.toggle("no-matches", shown === 0);
        if (empty) empty.classList.toggle("hidden", shown !== 0);
      };

      search?.addEventListener("input", apply);

      for (const btn of catButtons) {
        btn.addEventListener("click", () => {
          activeFamily = btn.dataset.family ?? "all";
          for (const b of catButtons) {
            const on = b === btn;
            b.classList.toggle("active", on);
            b.setAttribute("aria-pressed", String(on));
          }
          apply();
        });
      }

      for (const btn of viewButtons) {
        btn.addEventListener("click", () => {
          wrap.dataset.view = btn.dataset.viewBtn ?? "list";
          for (const b of viewButtons) {
            const on = b === btn;
            b.classList.toggle("active", on);
            b.setAttribute("aria-pressed", String(on));
          }
        });
      }
    }

    // ----- hero image: single "boot-up" scan sweep on hover -----
    // Plays once and always finishes, even if the pointer leaves mid-sweep;
    // re-hovering while it runs is ignored so it never restarts mid-way.
    const heroWrap = document.querySelector<HTMLElement>(".hero-img-wrap");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (heroWrap && !reduceMotion) {
      const sweep = heroWrap.querySelector<HTMLElement>(".hero-sweep");
      heroWrap.addEventListener("mouseenter", () => {
        if (heroWrap.classList.contains("sweeping")) return;
        heroWrap.classList.add("sweeping");
      });
      sweep?.addEventListener("animationend", () => heroWrap.classList.remove("sweeping"));
    }

    // ----- get started modal -----
    const modal = document.getElementById("get-started-modal");
    if (modal) {
      const open = () => modal.classList.add("is-open");
      const close = () => modal.classList.remove("is-open");
      for (const b of Array.from(document.querySelectorAll("[data-open-modal]"))) {
        b.addEventListener("click", open);
      }
      // Close on backdrop click or the close button; clicks inside the panel
      // (which has no data-close-modal) are ignored.
      modal.addEventListener("click", (e) => {
        const t = e.target as HTMLElement;
        if (t === modal || t.hasAttribute("data-close-modal")) close();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
      });
    }

    // ----- get started: agent picker + target toggle rewrite both commands -----
    const gsAgents = document.getElementById("gs-agents");
    if (gsAgents) {
      const promptName = document.getElementById("gs-prompt-name")!;
      const promptCopy = document.getElementById("gs-prompt-copy")!;
      const agentTag = document.getElementById("gs-agent-tag")!;
      const cliTarget = document.getElementById("gs-cli-target")!;
      const cliSlug = document.getElementById("gs-cli-slug")!;
      const cliCopy = document.getElementById("gs-cli-copy")!;
      const chips = Array.from(gsAgents.querySelectorAll<HTMLElement>(".gs-chip"));
      const targets = Array.from(
        document.querySelectorAll<HTMLElement>("#gs-target .gs-target-btn")
      );

      let slug = chips[0]?.dataset.slug ?? "";
      let label = chips[0]?.dataset.label ?? "";
      let tag = chips[0]?.dataset.tag ?? "";
      let target = "eve";

      const render = () => {
        const prompt = `Read atomeve.dev/start.md and add the ${label} agent.`;
        promptName.textContent = label;
        promptCopy.dataset.cmd = prompt;
        agentTag.textContent = tag;
        // init writes the target to atom-eve.json, so the add line needs no flag.
        const flag = target === "flue" ? " --target flue" : "";
        cliTarget.textContent = flag;
        cliSlug.textContent = slug;
        cliCopy.dataset.cmd = `npx atom-eve init${flag}\nnpx atom-eve add ${slug}`;
      };

      for (const chip of chips) {
        chip.addEventListener("click", () => {
          for (const c of chips) c.setAttribute("aria-pressed", String(c === chip));
          slug = chip.dataset.slug ?? slug;
          label = chip.dataset.label ?? label;
          tag = chip.dataset.tag ?? tag;
          render();
        });
      }
      for (const btn of targets) {
        btn.addEventListener("click", () => {
          for (const b of targets) b.setAttribute("aria-selected", String(b === btn));
          target = btn.dataset.target ?? "eve";
          render();
        });
      }
      render();
    }
  </script>

  <style>
    .gs-chip[aria-pressed="true"] {
      border-color: var(--color-cyan);
      background: var(--color-cyan);
      color: #0b0820;
    }
    .gs-target-btn[aria-selected="true"] {
      background: var(--color-cyan);
      color: #0b0820;
    }
  </style>
</Base>
