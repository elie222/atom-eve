---
import Glyph from "./Glyph.astro";
import type { AgentCard } from "../lib/data";

interface Props {
  agent: AgentCard;
}
const { agent } = Astro.props;
const c = agent.color;
const tags = agent.integrations ? agent.integrations.split(" · ") : [];
---

<div
  class="agent-row agent-item flex items-center gap-[14px] border-b border-edge px-[15px] py-[12px] transition-colors last:border-b-0 hover:bg-panel2"
  style={`--famh:${c}66`}
  data-family={agent.family}
>
  <div
    class="flex h-8 w-8 flex-none items-center justify-center rounded-[7px]"
    style={`background:${c}14;border:1px solid ${c}33`}
  >
    <Glyph glyph={agent.glyph} color={c} scale={4} />
  </div>

  <div class="min-w-0 flex-1">
    <div class="flex items-center gap-[10px]">
      <a
        href={`/agents/${agent.name}/`}
        class="truncate text-[14.5px] font-semibold text-ink transition-colors hover:text-eve"
      >
        {agent.title}
      </a>
      <span class="flex-none font-pixel text-[8px] tracking-[0.01em]" style={`color:${c}`}>
        {agent.categoryLabel.toUpperCase()}
      </span>
    </div>
    <div class="truncate text-[13px] leading-[1.5] text-muted">{agent.description}</div>
  </div>

  {
    tags.length > 0 && (
      <div class="hidden flex-none gap-[5px] lg:flex">
        {tags.map((t) => (
          <span class="rounded border border-edge px-[7px] py-[2px] font-mono text-[10.5px] text-muted2">
            {t}
          </span>
        ))}
      </div>
    )
  }

  <div class="flex flex-none gap-[7px]">
    <button
      class="copy-btn cursor-pointer rounded-[5px] border-none px-[12px] py-[6px] text-[12.5px] font-semibold text-[#0a0a0c]"
      style={`background:${c}`}
      data-cmd={agent.installCmd}
    >
      Copy install
    </button>
    <a
      href={`/agents/${agent.name}/`}
      class="rounded-[5px] border border-edge px-[10px] py-[6px] text-[12.5px] font-medium text-ink transition-colors hover:border-dim2 hover:bg-panel2"
      >Details</a
    >
  </div>
</div>
