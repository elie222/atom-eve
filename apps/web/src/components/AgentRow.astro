---
import Glyph from "./Glyph.astro";
import type { AgentCard } from "../lib/data";

interface Props {
  agent: AgentCard;
}
const { agent } = Astro.props;
const c = agent.color;
---

<a
  href={`/agents/${agent.name}/`}
  class="agent-row agent-item group flex items-stretch border-2 border-edge bg-panel shadow-[4px_4px_0_rgba(0,0,0,0.22)]"
  style={`--fam:${c}`}
  data-family={agent.family}
>
  <div class="w-[4px] flex-none" style={`background:${c}`}></div>
  <div class="flex min-w-0 flex-1 items-center gap-[14px] px-4 py-[13px]">
    <div
      class="flex h-[34px] w-[34px] flex-none items-center justify-center"
      style={`background:${c}18;border:2px solid ${c}40`}
    >
      <Glyph glyph={agent.glyph} color={c} scale={4} />
    </div>

    <span
      class="w-[96px] flex-none truncate font-pixel text-[8.5px] tracking-[0.01em]"
      style={`color:${c}`}
    >
      {agent.categoryLabel.toUpperCase()}
    </span>

    <span class="flex-none truncate text-[14px] font-semibold text-ink transition-colors group-hover:text-cyan max-md:max-w-[150px]">
      {agent.title}
    </span>

    <span class="min-w-0 flex-1 truncate text-[13.5px] text-ink2 max-sm:hidden">
      {agent.description}
    </span>

    <span
      class="w-[200px] flex-none truncate text-right font-mono text-[10.5px] text-muted2 max-lg:hidden"
    >
      {agent.integrations}
    </span>

    <span class="flex-none font-pixel text-[8px] tracking-[0.04em]" style={`color:${c}`}>
      VIEW →
    </span>
  </div>
</a>
