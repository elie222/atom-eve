---
interface Props {
  size?: number;
}
const { size = 24 } = Astro.props;
const inset = size >= 24 ? 2 : 1;
const dot = size >= 24 ? 6 : 5;
const dotPos = size >= 24 ? 9 : 7;
const rings = [
  { rot: 0, color: "#ff45c2" },
  { rot: 60, color: "#37d6ff" },
  { rot: -60, color: "#a974ff" },
];
---

<div style={`position:relative;width:${size}px;height:${size}px;flex:none`}>
  {
    rings.map((r) => (
      <div
        style={`position:absolute;inset:${inset}px;border:2px solid ${r.color};border-radius:50%;transform:${r.rot ? `rotate(${r.rot}deg) ` : ""}scaleY(0.42)`}
      />
    ))
  }
  <div
    style={`position:absolute;top:${dotPos}px;left:${dotPos}px;width:${dot}px;height:${dot}px;background:#fff;box-shadow:0 0 8px #ff45c2`}
  >
  </div>
</div>
