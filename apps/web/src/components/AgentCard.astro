---
import Glyph from "./Glyph.astro";
import type { AgentCard } from "../lib/data";

interface Props {
  agent: AgentCard;
}
const { agent } = Astro.props;
const c = agent.color;
---

<a
  href={`/agents/${agent.name}/`}
  class="agent-card agent-item group flex h-full flex-col border-2 border-edge bg-panel shadow-[5px_5px_0_rgba(0,0,0,0.28)]"
  style={`--fam:${c}`}
  data-family={agent.family}
>
  <div class="h-[4px]" style={`background:${c};box-shadow:0 0 10px ${c}66`}></div>
  <div class="flex flex-1 flex-col gap-[10px] p-4">
    <div
      class="flex h-[34px] w-[34px] flex-none items-center justify-center"
      style={`background:${c}18;border:2px solid ${c}40`}
    >
      <Glyph glyph={agent.glyph} color={c} scale={4} />
    </div>

    <div class="text-[15px] font-semibold leading-[1.3] text-ink transition-colors group-hover:text-cyan">
      {agent.title}
    </div>
    <div class="line-clamp-2 text-[13.5px] leading-[1.45] text-ink2">{agent.description}</div>

    <div class="mt-auto flex items-center justify-end pt-[5px]">
      <span class="font-pixel text-[8px] tracking-[0.04em] text-muted2 transition-colors group-hover:text-ink">VIEW →</span>
    </div>
  </div>
</a>
