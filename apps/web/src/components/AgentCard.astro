---
import Glyph from "./Glyph.astro";
import type { AgentCard } from "../lib/data";

interface Props {
  agent: AgentCard;
}
const { agent } = Astro.props;
const c = agent.color;
---

<article
  class="agent-card flex flex-col gap-[9px] rounded-lg border border-edge bg-panel p-[15px] pb-[14px]"
  style={`--famh:${c}66`}
  data-family={agent.family}
>
  <div class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-[9px]">
      <div
        class="flex h-8 w-8 flex-none items-center justify-center rounded-[7px]"
        style={`background:${c}14;border:1px solid ${c}33`}
      >
        <Glyph glyph={agent.glyph} color={c} scale={4} />
      </div>
      <div class="font-pixel text-[9px] leading-[1.4] tracking-[0.01em]" style={`color:${c}`}>
        {agent.categoryLabel.toUpperCase()}
      </div>
    </div>
    <span
      class="flex-none rounded border border-edge px-[6px] py-[2px] font-mono text-[10.5px] text-muted"
      >v{agent.version}</span
    >
  </div>

  <a href={`/agents/${agent.name}/`} class="text-[15.5px] font-semibold leading-[1.3] text-ink">
    {agent.title}
  </a>
  <div class="text-[13.5px] leading-[1.5] text-muted">{agent.description}</div>

  <div class="flex items-center gap-[9px]">
    {
      agent.memory ? (
        <span
          class="rounded font-mono text-[9.5px]"
          style={`color:${c};background:${c}1f;border:1px solid ${c}40;padding:2px 6px`}
        >
          ● MEMORY
        </span>
      ) : (
        <span class="rounded border border-edge px-[6px] py-[2px] font-mono text-[9.5px] text-muted">
          STATELESS
        </span>
      )
    }
  </div>

  <div class="font-mono text-[11px] leading-[1.4] text-muted2">{agent.integrations || "—"}</div>

  <div class="mt-[1px] flex items-center gap-[10px] font-mono text-[11px] text-dim">
    <span>{agent.familyLabel}</span>
    <span class="text-dim2">·</span>
    <span>{agent.targets}</span>
  </div>

  <div class="mt-[3px] flex gap-[7px]">
    <button
      class="copy-btn cursor-pointer rounded-[5px] border-none px-[13px] py-[7px] text-[13px] font-semibold text-[#0a0a0c]"
      style={`background:${c}`}
      data-cmd={agent.installCmd}
    >
      Copy agent
    </button>
    <a
      href={`/agents/${agent.name}/`}
      class="rounded-[5px] border border-edge px-[11px] py-[7px] text-[13px] font-medium text-ink transition-colors hover:border-dim2 hover:bg-panel2"
      >Details</a
    >
  </div>
</article>
