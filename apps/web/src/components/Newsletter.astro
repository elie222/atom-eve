---
import { NEWSLETTER_URL } from "../lib/format";
---

<!-- newsletter band — capture emails for new agent drops -->
<section id="newsletter" class="relative z-[2] mx-auto mt-9 max-w-[1200px] px-8">
  <div
    class="flex flex-wrap items-center justify-between gap-[30px] border-2 border-edge bg-panel p-[30px] shadow-[6px_6px_0_rgba(0,0,0,0.3)]"
  >
    <div class="max-w-[460px]">
      <div class="font-mono text-[11px] tracking-[0.08em] text-pink">// stay in the loop</div>
      <div class="mt-3 font-pixel text-[15px] leading-[1.5]">NEW AGENT DROPS</div>
      <p class="mt-[14px] text-[14.5px] leading-[1.6] text-muted">
        Get an email when we ship new agents. No spam, unsubscribe anytime.
      </p>
    </div>

    <!-- Native GET submit appends ?email=<value>; Youform prefills the field
         when its autofill param is named "email". Works with JS disabled. -->
    <form
      action={NEWSLETTER_URL}
      method="get"
      class="flex w-full max-w-[440px] flex-wrap items-stretch gap-3"
    >
      <label
        class="flex flex-1 min-w-[200px] cursor-text items-center gap-[10px] border-2 border-edge2 bg-bg2 px-4 py-3 shadow-[3px_3px_0_rgba(0,0,0,0.3)]"
      >
        <span class="font-mono text-[13px] text-dim">@</span>
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          class="flex-1 border-none bg-transparent text-left font-mono text-[13px] tracking-[0.02em] text-ink outline-none"
        />
      </label>
      <button
        type="submit"
        class="arcade-btn flex-none whitespace-nowrap bg-pink px-[22px] py-[15px] font-pixel text-[11px] leading-[1.5] tracking-[0.03em] text-[#0b0820] shadow-[6px_6px_0_#8a1668]"
      >
        NOTIFY ME ▸
      </button>
    </form>
  </div>
</section>
