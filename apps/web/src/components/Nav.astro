---
import AtomLogo from "./AtomLogo.astro";
import { REPO, NEWSLETTER_URL } from "../lib/format";

interface Props {
  variant?: "landing" | "detail";
}
const { variant = "landing" } = Astro.props;

const NOTIFY = { label: "Notify me", href: NEWSLETTER_URL, external: true };

const links =
  variant === "detail"
    ? [
        { label: "Browse", href: "/" },
        { label: "Docs", href: REPO },
        { label: "Contribute", href: REPO },
        NOTIFY,
      ]
    : [
        { label: "Docs", href: REPO },
        { label: "Contribute", href: REPO },
        NOTIFY,
      ];
---

<header class="relative z-[5] border-b-2 border-edge bg-bg/90">
  <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-[18px] px-[30px] py-[15px]">
    <a href="/" class="flex items-center gap-3">
      <AtomLogo size={24} />
      <div class="font-pixel text-[13px] tracking-[0.02em]">
        <span class="text-pink">ATOM</span> <span class="text-cyan">EVE</span>
      </div>
    </a>

    <nav class="hidden items-center gap-[26px] md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            target={"external" in l && l.external ? "_blank" : undefined}
            rel={"external" in l && l.external ? "noopener" : undefined}
            class="font-mono text-[12.5px] text-muted transition-colors hover:text-ink"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      {
        variant === "detail" ? (
          <a
            href={REPO}
            class="whitespace-nowrap border-2 border-edge px-[11px] py-[7px] font-mono text-[12px] text-ink transition-colors hover:border-amber"
          >
            <span class="text-amber">★</span> GitHub
          </a>
        ) : (
          <>
            <a
              href={REPO}
              class="whitespace-nowrap font-mono text-[12.5px] text-muted transition-colors hover:text-ink"
            >
              GitHub ↗
            </a>
            <button
              type="button"
              data-open-modal
              class="arcade-btn whitespace-nowrap bg-pink px-[14px] py-[11px] font-pixel text-[9px] leading-[1.5] tracking-[0.02em] text-[#0b0820] shadow-[3px_3px_0_#8a1668]"
            >
              GET STARTED
            </button>
          </>
        )
      }
    </div>
  </div>
</header>
