{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "website-qa",
  "title": "Product QA",
  "description": "Catch broken signup, onboarding, and core flows before users do, with a screenshotted report of what failed and how to fix it.",
  "category": "qa",
  "family": "engineering",
  "author": {
    "name": "atom-eve"
  },
  "version": "0.1.0",
  "targets": ["eve"],
  "integrations": ["agent-browser"],
  "connections": [
    {
      "name": "slack",
      "type": "platform",
      "auth": "vercel-connect"
    }
  ],
  "requiredEnv": ["SLACK_QA_CHANNEL_ID"],
  "dependencies": ["eve@^0.16.2", "ai@^7.0.4", "@vercel/connect@^0.2.10"],
  "skills": [{ "ref": "vercel-labs/agent-browser@agent-browser" }]
}
