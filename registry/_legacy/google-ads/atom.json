{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "google-ads",
  "title": "Google Ads Agent",
  "description": "Reviews campaign performance and proposes conservative budget, keyword, and negative-keyword actions.",
  "category": "ads",
  "family": "growth",
  "targets": ["eve", "flue"],
  "integrations": ["google-ads"],
  "connections": [
    {
      "name": "google-ads",
      "type": "custom-tool",
      "auth": "env"
    }
  ],
  "requiredEnv": [
    "GOOGLE_ADS_DEVELOPER_TOKEN",
    "GOOGLE_ADS_CLIENT_ID",
    "GOOGLE_ADS_CLIENT_SECRET",
    "GOOGLE_ADS_REFRESH_TOKEN",
    "GOOGLE_ADS_CUSTOMER_ID"
  ]
}
