{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "seo-improver",
  "title": "SEO Improver",
  "description": "Tracks where you rank each week, tells you exactly what to change to climb, and reports whether last week's changes worked.",
  "category": "seo",
  "family": "growth",
  "author": {
    "name": "atom-eve"
  },
  "version": "0.1.0",
  "targets": ["eve"],
  "integrations": ["dataforseo", "agent-browser", "github"],
  "connections": [{ "name": "dataforseo", "type": "mcp", "auth": "env" }],
  "requiredEnv": ["DATAFORSEO_LOGIN", "DATAFORSEO_PASSWORD"],
  "dependencies": ["eve@^0.16.2", "ai@^7.0.4"],
  "skills": [{ "ref": "vercel-labs/agent-browser@agent-browser" }]
}
