{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "support-replies",
  "title": "Support Replies",
  "description": "Turn open Intercom conversations into grounded draft replies and clear escalation notes.",
  "category": "support",
  "family": "support",
  "author": {
    "name": "atom-eve"
  },
  "version": "0.1.0",
  "targets": ["eve"],
  "integrations": ["intercom"],
  "connections": [
    {
      "name": "intercom",
      "type": "custom-tool",
      "auth": "env"
    }
  ],
  "requiredEnv": ["INTERCOM_ACCESS_TOKEN"],
  "dependencies": ["eve@^0.16.2", "ai@^7.0.4"]
}
