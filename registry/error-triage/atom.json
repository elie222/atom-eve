{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "error-triage",
  "title": "Error Triage Agent",
  "description": "Reviews recent production errors, groups regressions, and proposes read-only TDD fix plans.",
  "category": "observability",
  "family": "engineering",
  "targets": ["eve", "flue"],
  "integrations": ["sentry"],
  "connections": [
    {
      "name": "sentry",
      "type": "custom-tool",
      "auth": "env"
    }
  ],
  "requiredEnv": ["SENTRY_AUTH_TOKEN", "SENTRY_ORG", "SENTRY_PROJECT"]
}
