{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "standup-bot",
  "title": "Standup Bot",
  "description": "Get a ready-to-review daily standup digest of priorities, active threads, blockers, and wins drawn from your Slack channel.",
  "category": "productivity",
  "family": "ops",
  "author": {
    "name": "atom-eve"
  },
  "version": "0.1.0",
  "targets": ["eve"],
  "integrations": ["slack"],
  "connections": [
    {
      "name": "slack",
      "type": "custom-tool",
      "auth": "env"
    }
  ],
  "requiredEnv": ["SLACK_BOT_TOKEN", "SLACK_CHANNEL_ID"],
  "dependencies": ["eve@^0.16.2", "ai@^7.0.4"]
}
