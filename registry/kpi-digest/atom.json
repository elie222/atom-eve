{
  "$schema": "https://atomeve.dev/schema/atom.json",
  "name": "kpi-digest",
  "title": "KPI Digest Agent",
  "description": "Assembles revenue KPIs from Stripe and product KPIs from PostHog into one weekly read-only digest.",
  "category": "analytics",
  "family": "data",
  "targets": ["eve", "flue"],
  "integrations": ["stripe", "posthog"],
  "connections": [
    {
      "name": "stripe",
      "type": "custom-tool",
      "auth": "env"
    },
    {
      "name": "posthog",
      "type": "custom-tool",
      "auth": "env"
    }
  ],
  "requiredEnv": ["STRIPE_SECRET_KEY", "POSTHOG_API_KEY", "POSTHOG_PROJECT_ID"]
}
